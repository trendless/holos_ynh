# Environment
NODE_ENV=production

# Server
PORT=__PORT__
HOST=127.0.0.1
DOMAIN=__DOMAIN__
PUBLIC_URL=https://__DOMAIN__

# Security - CRITICAL: Generate strong random values!
JWT_SECRET=__JWT_SECRET__

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=__DB_NAME__
DB_USER=__DB_USER__
DB_PASSWORD=__DB_PWD__
DB_MAX_CONNECTIONS=20
DB_SSL=false

# Redis (Cache & Rate Limiting)
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
#REDIS_PASSWORD=<redis-password>
REDIS_DB=__REDIS_DB__
REDIS_TTL=300

# Limits
MAX_USERS_PER_IP=10
HEARTBEAT_TIMEOUT=120000
CLEANUP_INTERVAL=300000
RATE_LIMIT_PER_MIN=100
MAX_PROXY_TIMEOUT=5000

# Features
ENABLE_CACHE=true
ENABLE_METRICS=true

# Cache
CACHE_TTL=60000
CACHE_MAX_SIZE=1000

# Admin & Email Configuration
# Note: Admin account is created interactively during database initialization
# Email/SMTP configuration is managed via the Admin Dashboard and stored in database (email_config table)
# Registration settings and email verification mode are also managed via Admin Dashboard (server_settings table)

# Monitoring
# Token for accessing /metrics endpoint (Prometheus scraping)
METRICS_TOKEN=__TOKEN__

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Tunnel Server (Required for mobile app connectivity)
TUNNEL_SERVER_PORT=__PORT_SERVER__
TUNNEL_DOMAIN=tunnel.__DOMAIN__
# REQUIRED: Generate with 'openssl rand -base64 48'
TUNNEL_INTERNAL_API_KEY=__API_KEY__
# Internal URL for relay-to-tunnel communication
TUNNEL_INTERNAL_URL=http://127.0.0.1:__PORT_SERVER__


ENCRYPTION_KEY=__API_KEY__
ADMIN_PASSWORD='__PASSWORD__'
